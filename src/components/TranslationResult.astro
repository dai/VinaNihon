---
import { UI_COPY } from "../lib/ui-copy";

const ui = UI_COPY.ja;
---

<section id="translationResult" class="surface-card panel-card result-card is-hidden" aria-live="polite">
  <h2 class="section-heading" data-i18n="resultsHeading">{ui.resultsHeading}</h2>

  <section class="result-section">
    <div class="result-section-head">
      <h3 class="section-subheading" data-i18n="mainTranslationHeading">{ui.mainTranslationHeading}</h3>
      <div class="action-group flex flex-wrap items-center gap-2">
        <button
          type="button"
          class="voice-button action-button icon-action-button"
          data-voice-action="speak"
          data-speak-kind="main"
          data-default-label-key="speakLabel"
          data-default-label={ui.speakLabel}
          data-icon-idle="🔊"
          data-icon-active="⏹"
          data-tooltip-idle-key="tooltipMainSpeak"
          data-tooltip-active-key="stopLabel"
          aria-label={ui.speakLabel}
          title={ui.tooltipMainSpeak}
        >
          🔊
        </button>
        <button
          type="button"
          class="copy-button action-button icon-action-button"
          data-copy-kind="main"
          data-default-label-key="copyLabel"
          data-copied-label-key="copiedLabel"
          data-icon-idle="⧉"
          data-icon-copied="✓"
          data-tooltip-idle-key="tooltipMainCopy"
          data-tooltip-copied-key="copiedLabel"
          aria-label={ui.copyLabel}
          title={ui.tooltipMainCopy}
        >
          ⧉
        </button>
      </div>
    </div>
    <p id="mainTranslation" class="result-body whitespace-pre-wrap"></p>
    <div class="details-trigger-row">
      <button
        type="button"
        id="loadDetailsButton"
        class="action-button"
        data-load-details
      >
        {ui.loadDetailsIdle}
      </button>
      <p id="detailsStatus" class="status-line text-sm text-muted-foreground" aria-live="polite"></p>
    </div>
  </section>

  <div id="translationDetails" class="details-block is-hidden">
  <section class="result-section">
    <div class="result-section-head">
      <h3 class="section-subheading" data-i18n="alternativesHeading">{ui.alternativesHeading}</h3>
      <div class="action-group flex flex-wrap items-center gap-2">
        <button
          type="button"
          class="voice-button action-button icon-action-button"
          data-voice-action="speak"
          data-speak-kind="alternatives"
          data-default-label-key="speakLabel"
          data-default-label={ui.speakLabel}
          data-icon-idle="🔊"
          data-icon-active="⏹"
          data-tooltip-idle-key="tooltipAlternativesSpeak"
          data-tooltip-active-key="stopLabel"
          aria-label={ui.speakLabel}
          title={ui.tooltipAlternativesSpeak}
        >
          🔊
        </button>
        <button
          type="button"
          class="copy-button action-button icon-action-button"
          data-copy-kind="alternatives"
          data-default-label-key="copyLabel"
          data-copied-label-key="copiedLabel"
          data-icon-idle="⧉"
          data-icon-copied="✓"
          data-tooltip-idle-key="tooltipAlternativesCopy"
          data-tooltip-copied-key="copiedLabel"
          aria-label={ui.copyLabel}
          title={ui.tooltipAlternativesCopy}
        >
          ⧉
        </button>
      </div>
    </div>
    <ul id="alternativesList" class="result-list result-body"></ul>
  </section>

  <section class="result-section">
    <div class="result-section-head">
      <h3 class="section-subheading" data-i18n="nuanceHeading">{ui.nuanceHeading}</h3>
      <div class="action-group flex flex-wrap items-center gap-2">
        <button
          type="button"
          class="voice-button action-button icon-action-button"
          data-voice-action="speak"
          data-speak-kind="nuance"
          data-default-label-key="speakLabel"
          data-default-label={ui.speakLabel}
          data-icon-idle="🔊"
          data-icon-active="⏹"
          data-tooltip-idle-key="tooltipNuanceSpeak"
          data-tooltip-active-key="stopLabel"
          aria-label={ui.speakLabel}
          title={ui.tooltipNuanceSpeak}
        >
          🔊
        </button>
        <button
          type="button"
          class="copy-button action-button icon-action-button"
          data-copy-kind="nuance"
          data-default-label-key="copyLabel"
          data-copied-label-key="copiedLabel"
          data-icon-idle="⧉"
          data-icon-copied="✓"
          data-tooltip-idle-key="tooltipNuanceCopy"
          data-tooltip-copied-key="copiedLabel"
          aria-label={ui.copyLabel}
          title={ui.tooltipNuanceCopy}
        >
          ⧉
        </button>
      </div>
    </div>
    <ul id="nuanceNotesList" class="result-list result-body"></ul>
  </section>

  <section class="result-section">
    <div class="result-section-head">
      <h3 class="section-subheading" data-i18n="repliesHeading">{ui.repliesHeading}</h3>
      <div class="action-group flex flex-wrap items-center gap-2">
        <button
          type="button"
          class="voice-button action-button icon-action-button"
          data-voice-action="speak"
          data-speak-kind="replies"
          data-default-label-key="speakLabel"
          data-default-label={ui.speakLabel}
          data-icon-idle="🔊"
          data-icon-active="⏹"
          data-tooltip-idle-key="tooltipRepliesSpeak"
          data-tooltip-active-key="stopLabel"
          aria-label={ui.speakLabel}
          title={ui.tooltipRepliesSpeak}
        >
          🔊
        </button>
        <button
          type="button"
          class="copy-button action-button icon-action-button"
          data-copy-kind="replies"
          data-default-label-key="copyLabel"
          data-copied-label-key="copiedLabel"
          data-icon-idle="⧉"
          data-icon-copied="✓"
          data-tooltip-idle-key="tooltipRepliesCopy"
          data-tooltip-copied-key="copiedLabel"
          aria-label={ui.copyLabel}
          title={ui.tooltipRepliesCopy}
        >
          ⧉
        </button>
      </div>
    </div>
    <ul id="suggestedRepliesList" class="result-list result-body"></ul>
  </section>
  </div>
</section>
