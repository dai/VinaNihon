<form
  id="translator-form"
  class="surface-card grid gap-5 rounded-3xl border border-border/70 bg-card/85 p-5 shadow-[0_24px_64px_oklch(0.22_0.03_255_/_0.18)] backdrop-blur-md sm:p-7"
  novalidate
>
  <header class="grid gap-2">
    <h1 class="title-heading text-balance text-3xl tracking-tight sm:text-4xl">VinaNihon</h1>
    <p class="text-sm text-muted-foreground sm:text-base">ベトナム語↔日本語の自然翻訳</p>
  </header>

  <div class="grid gap-3 md:grid-cols-[1fr_auto_1fr] md:items-end">
    <label class="field">
      <span class="field-label">入力言語</span>
      <select id="sourceLang" name="sourceLang" class="form-control">
        <option value="ja" selected>日本語🇯🇵</option>
        <option value="vi">ベトナム語🇻🇳</option>
      </select>
    </label>

    <button type="button" class="swap-button" id="swapLanguages" aria-label="入力言語と翻訳先言語を入れ替える">
      ⇄
    </button>

    <label class="field">
      <span class="field-label">翻訳先言語</span>
      <select id="targetLang" name="targetLang" class="form-control">
        <option value="ja">日本語🇯🇵</option>
        <option value="vi" selected>ベトナム語🇻🇳</option>
      </select>
    </label>
  </div>

  <label class="field">
    <span class="field-label">翻訳したい文</span>
    <textarea
      id="sourceText"
      name="text"
      rows="6"
      placeholder="ここに文章を入力してください"
      class="form-control min-h-44 resize-y"
      required
    ></textarea>
    <div class="mt-2 flex flex-wrap gap-2">
      <button
        type="button"
        class="voice-button action-button"
        data-voice-action="speak"
        data-speak-kind="source"
        data-default-label="読み上げ"
        aria-label="入力文を読み上げる"
      >
        読み上げ
      </button>
      <button
        type="button"
        class="voice-button action-button"
        id="sourceListenButton"
        data-voice-action="listen"
        data-default-label="音声入力"
        aria-label="音声入力を開始する"
      >
        音声入力
      </button>
    </div>
  </label>

  <div class="grid gap-3 sm:grid-cols-2">
    <label class="field">
      <span class="field-label">モード</span>
      <select id="mode" name="mode" class="form-control">
        <option value="daily" selected>daily</option>
        <option value="work">work</option>
        <option value="customer-service">customer-service</option>
        <option value="hospital">hospital</option>
      </select>
    </label>

    <label class="field">
      <span class="field-label">トーン</span>
      <select id="tone" name="tone" class="form-control">
        <option value="casual" selected>casual</option>
        <option value="normal">normal</option>
        <option value="polite">polite</option>
      </select>
    </label>
  </div>

  <button type="submit" class="submit-button mt-1" id="translateSubmit">翻訳する</button>
  <p id="formStatus" class="status-line text-sm text-muted-foreground" aria-live="polite"></p>
  <p id="voiceStatus" class="status-line text-sm text-muted-foreground" aria-live="polite"></p>
  <p id="formError" class="status-line text-sm font-medium text-destructive" role="alert" hidden></p>
</form>
