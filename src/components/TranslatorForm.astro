---
import { UI_COPY } from "../lib/ui-copy";

const ui = UI_COPY.ja;
---

<form id="translator-form" class="surface-card panel-card translator-card" novalidate>
  <header class="hero-header">
    <div class="hero-copy">
      <h1 class="title-heading text-balance">VinaNihon</h1>
      <p id="appSubtitle" class="title-subheading text-balance" data-i18n="appSubtitle">{ui.appSubtitle}</p>
    </div>
    <div class="flex items-center gap-3">
      <a href="https://github.com/dai" target="_blank" rel="noopener noreferrer" aria-label="GitHub" class="text-muted-foreground hover:text-foreground transition">
        <img src="https://img.shields.io/github/followers/dai" alt="GitHub followers" height="20" style="display: block;">
      </a>
      <a href="https://x.com/daisuke" target="_blank" rel="noopener noreferrer" aria-label="X (Twitter)" class="text-muted-foreground hover:text-foreground transition">
        <img src="https://img.shields.io/twitter/follow/daisuke" alt="X (Twitter) followers" height="20" style="display: block;">
      </a>
    </div>
  </header>

  <div class="grid gap-3 md:grid-cols-[1fr_auto_1fr] md:items-end">
    <label class="field">
      <span class="field-label" data-i18n="sourceLangLabel">{ui.sourceLangLabel}</span>
      <select id="sourceLang" name="sourceLang" class="form-control">
        <option value="ja" selected data-option-group="language" data-option-value="ja">{ui.languageOptions.ja}</option>
        <option value="vi" data-option-group="language" data-option-value="vi">{ui.languageOptions.vi}</option>
      </select>
    </label>

    <button
      type="button"
      class="swap-button"
      id="swapLanguages"
      data-i18n-aria-label="swapAriaLabel"
      aria-label={ui.swapAriaLabel}
    >
      ⇄
    </button>

    <label class="field">
      <span class="field-label" data-i18n="targetLangLabel">{ui.targetLangLabel}</span>
      <select id="targetLang" name="targetLang" class="form-control">
        <option value="ja" data-option-group="language" data-option-value="ja">{ui.languageOptions.ja}</option>
        <option value="vi" selected data-option-group="language" data-option-value="vi">{ui.languageOptions.vi}</option>
      </select>
    </label>
  </div>

  <label class="field">
    <span class="field-label" data-i18n="textLabel">{ui.textLabel}</span>
    <textarea
      id="sourceText"
      name="text"
      rows="6"
      placeholder={ui.textPlaceholder}
      data-i18n-placeholder="textPlaceholder"
      class="form-control source-textarea"
      required
    ></textarea>
  </label>

  <div class="grid gap-3 sm:grid-cols-2">
    <label class="field">
      <span class="field-label" data-i18n="modeLabel">{ui.modeLabel}</span>
      <select id="mode" name="mode" class="form-control">
        <option value="daily" selected data-option-group="mode" data-option-value="daily">{ui.modeOptions.daily}</option>
        <option value="work" data-option-group="mode" data-option-value="work">{ui.modeOptions.work}</option>
        <option value="customer-service" data-option-group="mode" data-option-value="customer-service">
          {ui.modeOptions["customer-service"]}
        </option>
        <option value="hospital" data-option-group="mode" data-option-value="hospital">{ui.modeOptions.hospital}</option>
      </select>
    </label>

    <label class="field">
      <span class="field-label" data-i18n="toneLabel">{ui.toneLabel}</span>
      <select id="tone" name="tone" class="form-control">
        <option value="casual" selected data-option-group="tone" data-option-value="casual">{ui.toneOptions.casual}</option>
        <option value="normal" data-option-group="tone" data-option-value="normal">{ui.toneOptions.normal}</option>
        <option value="polite" data-option-group="tone" data-option-value="polite">{ui.toneOptions.polite}</option>
      </select>
    </label>
  </div>

  <button
    type="submit"
    class="submit-button mt-1"
    id="translateSubmit"
    data-submit-idle-key="submitIdle"
    data-submit-loading-key="submitLoading"
  >
    {ui.submitIdle}
  </button>

  <div class="voice-form-controls flex flex-wrap gap-2 mt-3">
    <button
      type="button"
      class="voice-button action-button"
      data-voice-action="speak"
      data-speak-kind="source"
      data-default-label-key="speakLabel"
      data-default-label={ui.speakLabel}
      aria-label={ui.speakLabel}
      disabled
    >
      {ui.speakLabel}
    </button>
    <button
      type="button"
      class="voice-button action-button"
      id="sourceListenButton"
      data-voice-action="listen"
      data-default-label-key="listenLabel"
      data-default-label={ui.listenLabel}
      aria-label={ui.listenLabel}
      disabled
    >
      {ui.listenLabel}
    </button>
  </div>

  <p id="formStatus" class="status-line text-sm text-muted-foreground" aria-live="polite"></p>
  <p id="voiceStatus" class="status-line text-sm text-muted-foreground" aria-live="polite"></p>
  <p id="formError" class="status-line text-sm font-medium text-destructive" role="alert" hidden></p>
</form>
