---
import "@fontsource/geist-sans/400.css";
import "@fontsource/geist-sans/600.css";
import "@fontsource/geist-sans/700.css";
import "@fontsource/geist-mono/400.css";
import "@fontsource/geist-mono/500.css";
import "@fontsource/noto-sans/300.css";
import "@fontsource/noto-sans/400.css";
import "@fontsource/noto-sans/600.css";
import "@fontsource/noto-sans-jp/300.css";
import "@fontsource/noto-sans-jp/400.css";
import "@fontsource/noto-sans-jp/600.css";
import "@fontsource/noto-serif-jp/300.css";
import "@fontsource/parisienne/400.css";
import "../styles/global.css";
import { DEFAULT_THEME, STORAGE_KEYS, THEME_COLORS } from "../lib/ui-copy";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "VinaNihon",
  description = "ベトナム語↔日本語に特化したシンプル翻訳ツール"
} = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta id="page-description" name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="shortcut icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta id="theme-color-meta" name="theme-color" content={THEME_COLORS[DEFAULT_THEME]} />
    <title id="page-title">{title}</title>
    <script
      is:inline
      define:vars={{
        defaultTheme: DEFAULT_THEME,
        storageKeys: STORAGE_KEYS,
        themeColors: THEME_COLORS
      }}
    >
      (() => {
        const root = document.documentElement;
        const storageThemeKey = storageKeys.theme;

        let nextTheme = defaultTheme;

        try {
          const storedTheme = localStorage.getItem(storageThemeKey);
          if (storedTheme === "dark" || storedTheme === "light") {
            nextTheme = storedTheme;
          }
        } catch {
          nextTheme = defaultTheme;
        }

        root.dataset.theme = nextTheme;

        const themeColorMeta = document.querySelector('meta[name="theme-color"]');
        if (themeColorMeta instanceof HTMLMetaElement) {
          themeColorMeta.content = themeColors[nextTheme] || themeColors.light;
        }

        // Fetch initial UI locale from session API
        fetch("/api/session-locale")
          .then((res) => res.json())
          .then((data) => {
            if (data.uiLocale === "ja" || data.uiLocale === "vi") {
              root.lang = data.uiLocale;
              updateLocaleToggleInitial(data.uiLocale);
            }
          })
          .catch(() => {
            root.lang = "ja";
            updateLocaleToggleInitial("ja");
          });
      })();

      function updateLocaleToggleInitial(locale) {
        const localeToggle = document.getElementById("localeToggle");
        if (!localeToggle) return;
        const jaBtn = localeToggle.querySelector('[data-locale="ja"]');
        const viBtn = localeToggle.querySelector('[data-locale="vi"]');
        if (jaBtn instanceof HTMLButtonElement) {
          jaBtn.setAttribute("aria-pressed", locale === "ja" ? "true" : "false");
        }
        if (viBtn instanceof HTMLButtonElement) {
          viBtn.setAttribute("aria-pressed", locale === "vi" ? "true" : "false");
        }
      }
    </script>
  </head>
  <body class="min-h-dvh">
    <div class="locale-toggle-container">
      <div id="localeToggle" class="locale-toggle" role="group" aria-label="UI Language">
        <button type="button" class="locale-toggle-segment" data-locale="ja" aria-pressed="true">日本語</button>
        <button type="button" class="locale-toggle-segment" data-locale="vi" aria-pressed="false">ベトナム語</button>
      </div>
    </div>
    <slot />
  </body>
</html>
