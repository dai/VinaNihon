---
import { UI_COPY } from "../lib/ui-copy";

const ui = UI_COPY.ja;
---

<section id="translationResult" class="surface-card panel-card result-card is-hidden" aria-live="polite">
  <h2 class="section-heading" data-i18n="resultsHeading">{ui.resultsHeading}</h2>

  <section class="result-section">
    <div class="result-section-head">
      <h3 class="section-subheading" data-i18n="mainTranslationHeading">{ui.mainTranslationHeading}</h3>
      <div class="action-group flex flex-wrap items-center gap-2">
        <button
          type="button"
          class="voice-button action-button"
          data-voice-action="speak"
          data-speak-kind="main"
          data-default-label-key="speakLabel"
          data-default-label={ui.speakLabel}
          aria-label={ui.speakLabel}
        >
          {ui.speakLabel}
        </button>
        <button
          type="button"
          class="copy-button action-button"
          data-copy-kind="main"
          data-default-label-key="copyLabel"
          data-copied-label-key="copiedLabel"
          aria-label={ui.copyLabel}
        >
          {ui.copyLabel}
        </button>
      </div>
    </div>
    <p id="mainTranslation" class="result-body whitespace-pre-wrap"></p>
  </section>

  <section class="result-section">
    <div class="result-section-head">
      <h3 class="section-subheading" data-i18n="alternativesHeading">{ui.alternativesHeading}</h3>
      <div class="action-group flex flex-wrap items-center gap-2">
        <button
          type="button"
          class="voice-button action-button"
          data-voice-action="speak"
          data-speak-kind="alternatives"
          data-default-label-key="speakLabel"
          data-default-label={ui.speakLabel}
          aria-label={ui.speakLabel}
        >
          {ui.speakLabel}
        </button>
        <button
          type="button"
          class="copy-button action-button"
          data-copy-kind="alternatives"
          data-default-label-key="copyLabel"
          data-copied-label-key="copiedLabel"
          aria-label={ui.copyLabel}
        >
          {ui.copyLabel}
        </button>
      </div>
    </div>
    <ul id="alternativesList" class="result-list result-body"></ul>
  </section>

  <section class="result-section">
    <div class="result-section-head">
      <h3 class="section-subheading" data-i18n="nuanceHeading">{ui.nuanceHeading}</h3>
      <div class="action-group flex flex-wrap items-center gap-2">
        <button
          type="button"
          class="voice-button action-button"
          data-voice-action="speak"
          data-speak-kind="nuance"
          data-default-label-key="speakLabel"
          data-default-label={ui.speakLabel}
          aria-label={ui.speakLabel}
        >
          {ui.speakLabel}
        </button>
        <button
          type="button"
          class="copy-button action-button"
          data-copy-kind="nuance"
          data-default-label-key="copyLabel"
          data-copied-label-key="copiedLabel"
          aria-label={ui.copyLabel}
        >
          {ui.copyLabel}
        </button>
      </div>
    </div>
    <ul id="nuanceNotesList" class="result-list result-body"></ul>
  </section>

  <section class="result-section">
    <div class="result-section-head">
      <h3 class="section-subheading" data-i18n="repliesHeading">{ui.repliesHeading}</h3>
      <div class="action-group flex flex-wrap items-center gap-2">
        <button
          type="button"
          class="voice-button action-button"
          data-voice-action="speak"
          data-speak-kind="replies"
          data-default-label-key="speakLabel"
          data-default-label={ui.speakLabel}
          aria-label={ui.speakLabel}
        >
          {ui.speakLabel}
        </button>
        <button
          type="button"
          class="copy-button action-button"
          data-copy-kind="replies"
          data-default-label-key="copyLabel"
          data-copied-label-key="copiedLabel"
          aria-label={ui.copyLabel}
        >
          {ui.copyLabel}
        </button>
      </div>
    </div>
    <ul id="suggestedRepliesList" class="result-list result-body"></ul>
  </section>
</section>
