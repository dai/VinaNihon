<section id="translationResult" class="card result-card is-hidden" aria-live="polite">
  <h2 class="result-title">翻訳結果</h2>

  <section class="result-section">
    <div class="result-section-head">
      <h3>主翻訳</h3>
      <button type="button" class="copy-button" data-copy-kind="main" aria-label="主翻訳をコピー">
        コピー
      </button>
    </div>
    <p id="mainTranslation" class="main-translation"></p>
  </section>

  <section class="result-section">
    <div class="result-section-head">
      <h3>言い換え候補</h3>
      <button type="button" class="copy-button" data-copy-kind="alternatives" aria-label="言い換え候補をコピー">
        コピー
      </button>
    </div>
    <ul id="alternativesList" class="result-list"></ul>
  </section>

  <section class="result-section">
    <div class="result-section-head">
      <h3>ニュアンスメモ</h3>
      <button type="button" class="copy-button" data-copy-kind="nuance" aria-label="ニュアンスメモをコピー">
        コピー
      </button>
    </div>
    <ul id="nuanceNotesList" class="result-list"></ul>
  </section>

  <section class="result-section">
    <div class="result-section-head">
      <h3>返信例</h3>
      <button type="button" class="copy-button" data-copy-kind="replies" aria-label="返信例をコピー">
        コピー
      </button>
    </div>
    <ul id="suggestedRepliesList" class="result-list"></ul>
  </section>
</section>
