---
import TranslatorForm from "../components/TranslatorForm.astro";
import TranslationHistory from "../components/TranslationHistory.astro";
import TranslationResult from "../components/TranslationResult.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  DEFAULT_THEME,
  DEFAULT_UI_LOCALE,
  STORAGE_KEYS,
  THEME_COLORS,
  UI_COPY
} from "../lib/ui-copy";

const ui = UI_COPY.ja;
const emptyListValues = Object.values(UI_COPY).map((copy) => copy.emptyList);
---

<BaseLayout title={ui.pageTitle} description={ui.pageDescription}>
  <main class="page-shell">
    <section class="main-column">
      <TranslatorForm />
      <TranslationResult />
    </section>

    <aside class="history-column">
      <TranslationHistory />
    </aside>
  </main>
  <footer class="site-footer">
    <span data-i18n="footerAuthorLabel">{ui.footerAuthorLabel}</span>
    <a
      href="https://github.com/dai"
      target="_blank"
      rel="noopener noreferrer"
      class="text-primary underline decoration-primary/50 decoration-1 underline-offset-2 transition hover:text-accent"
    >
      dai
    </a>
    <span>/</span>
    <span data-i18n="footerXLabel">{ui.footerXLabel}</span>
    <a
      href="https://x.com/daisuke"
      target="_blank"
      rel="noopener noreferrer"
      class="text-primary underline decoration-primary/50 decoration-1 underline-offset-2 transition hover:text-accent"
    >
      @daisuke
    </a>
  </footer>

  <script
    is:inline
    define:vars={{
      defaultLocale: DEFAULT_UI_LOCALE,
      defaultTheme: DEFAULT_THEME,
      emptyListValues,
      storageKeys: STORAGE_KEYS,
      themeColors: THEME_COLORS,
      uiCopy: UI_COPY
    }}
  >
    window.__TRANSLATOR_CONFIG__ = {
      defaultLocale,
      defaultTheme,
      emptyListValues,
      storageKeys,
      themeColors,
      uiCopy
    };
  </script>
  <script src="../scripts/translator.ts"></script>
</BaseLayout>
